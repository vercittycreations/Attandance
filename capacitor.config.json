{
  "appId": "com.vercitty.attendance",
  "appName": "WorkforcePro",
  "webDir": "dist",
  "bundledWebRuntime": false,
  "server": {
    "url": "https://attandance-rho.vercel.app",
    "cleartext": false,
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0a0b14",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0a0b14"
    }
  }
}